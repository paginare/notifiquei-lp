---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PlatformShowcase from "../components/PlatformShowcase.astro";
import Capabilities from "../components/Capabilities.astro";
import ZoomReveal from "../components/ZoomReveal.astro";
import CreatorsMarquee from "../components/CreatorsMarquee.astro";
import DayInLife from "../components/DayInLife.astro";
import StickyCta from "../components/StickyCta.astro";

const SRC = "home"; // atribuição A/B: identifica a landing de origem (?src=) p/ o webhook da Cakto
const FREE = `https://app.notifiquei.com.br/auth?src=${SRC}`; // signup grátis (entrada do funil, sem cartão)
const WPP = "https://wa.me/551231995949";

const steps = [
  {
    n: "01",
    title: "Conecte seu Instagram",
    body: "Login pela Meta oficial, em poucos cliques. Zero senha exposta, zero risco, zero enrolação.",
  },
  {
    n: "02",
    title: "Escolha os gatilhos",
    body: "Palavra no comentário, DM recebido, resposta de story — você decide o que ativa cada automação.",
  },
  {
    n: "03",
    title: "Relaxe e venda",
    body: "Ele responde, qualifica, manda o link e só te chama quando o cliente já está pronto pra comprar.",
  },
];

const plans = [
  {
    name: "Solo",
    price: "99",
    blurb: "Criador iniciante, operação pequena.",
    hrefM: "https://pay.cakto.com.br/35rmdfj",
    hrefA: "https://pay.cakto.com.br/37feerd",
    cta: "Começar com Solo",
    featured: true,
    features: ["1 conta — Instagram + TikTok", "Automações ilimitadas", "Templates completos", "Atendimento via chat", "Novidades antes de todo mundo"],
  },
  {
    name: "Pro",
    price: "499",
    blurb: "Pra quem já escalou um pouco.",
    hrefM: "https://pay.cakto.com.br/52z4k9u",
    hrefA: "https://pay.cakto.com.br/3adhw97",
    cta: "Começar com Pro",
    featured: false,
    features: ["5 contas — Instagram + TikTok", "Times e divisão por equipe", "Automações ilimitadas", "Templates completos", "Atendimento via chat", "Novidades antes de todo mundo"],
  },
  {
    name: "Business",
    price: "799",
    blurb: "Agência e operação grande.",
    hrefM: "https://pay.cakto.com.br/3e8f2ba",
    hrefA: "https://pay.cakto.com.br/37q27z8",
    cta: "Começar com Business",
    featured: false,
    features: ["10 contas — Instagram + TikTok", "Times e divisão por equipe", "Automações ilimitadas", "Templates completos", "Atendimento VIP prioritário"],
  },
];

const faqs = [
  { q: "Isso pode bloquear meu Instagram?", a: "Não. Somos provedores oficiais da Meta e usamos exclusivamente a API oficial do Instagram. Zero automação disfarçada, zero quebra de regra, zero risco de banimento." },
  { q: "Preciso saber programar?", a: "Nada. Zero código. Se você sabe mandar mensagem no Instagram, sabe usar o Notifiquei. A interface é toda visual." },
  { q: "O Notifiquei responde sozinho, com IA?", a: "Sim. O Agente de IA responde DMs e comentários na sua voz, usando uma base de conhecimento que você ensina — e lembra do contexto da conversa. Quando o lead esquenta, ele te avisa pra você fechar." },
  { q: "Funciona pra e-commerce?", a: "Sim. Temos clientes vendendo moda, cosméticos, suplementos e produtos físicos em geral. O fluxo ideal muda um pouco, mas tem template pronto pra isso." },
  { q: "Qual a diferença pro ManyChat?", a: "Mais barato, suporte em português, interface mais simples e foco no mercado brasileiro. Se você já usa ManyChat e tá feliz, não precisa trocar. Se acha complicado ou caro, o Notifiquei foi feito pra você." },
  { q: "Funciona com poucos seguidores?", a: "Funciona com conta de qualquer tamanho. Quem responde rápido vende mais — não importa se você tem 500 ou 500 mil seguidores. Conta menor costuma sentir o resultado primeiro." },
  { q: "Preciso de conta comercial ou profissional?", a: "Sim, uma conta Profissional ou de Criador no Instagram — gratuita de ativar e leva 1 minuto. É exigência da própria API oficial da Meta." },
  { q: "Funciona com TikTok?", a: "Sim. O Notifiquei automatiza as DMs do TikTok (conta Business) — e cada plano já conecta 1 Instagram + 1 TikTok no mesmo preço. Você automatiza os dois canais sem pagar dobrado." },
  { q: "Posso cancelar quando quiser?", a: "Sim, sem fidelidade — você cancela a qualquer momento direto pelo painel. E todo plano pago tem garantia de 7 dias: se não rolar, devolvemos 100% do valor." },
];

// Curado: só logos com fundo transparente e cor real (sem as brancas/fundo-branco).
const clientes = [
  "gummy.png", "responda.png", "rosa-selvagem.png",
  "vert-sophistique.png", "cikiy.svg", "debran.svg",
];
// largura intrínseca de cada logo quando renderizado a 30px de altura — evita CLS (unsized-images)
const logoDims: Record<string, number> = {
  "gummy.png": 83, "responda.png": 178, "rosa-selvagem.png": 180,
  "vert-sophistique.png": 51, "cikiy.svg": 59, "debran.svg": 100,
};

// ---- SEO structured data ----
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://www.notifiquei.com.br/#org",
    name: "Notifiquei",
    legalName: "Notifiquei Tecnologia",
    url: "https://www.notifiquei.com.br",
    logo: "https://www.notifiquei.com.br/assets/favicon-180.png",
    description: "Ferramenta brasileira de automação de Instagram (DMs, comentários e stories) pela API oficial da Meta, para criadores e negócios.",
    taxID: "59.859.848/0001-13",
    sameAs: [
      "https://www.instagram.com/notifiquei.com.br/",
      "https://www.youtube.com/@notifiqueicombr",
      "https://br.linkedin.com/company/notifiquei",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Notifiquei",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    description: "Automação de Instagram e TikTok pela API oficial da Meta: responde comentários e DMs automaticamente, com agente de IA. Alternativa brasileira ao ManyChat.",
    url: "https://www.notifiquei.com.br",
    publisher: { "@id": "https://www.notifiquei.com.br/#org" },
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "BRL",
      lowPrice: "99",
      highPrice: "799",
      offerCount: plans.length,
      offers: plans.map((p) => ({
        "@type": "Offer",
        name: `Plano ${p.name}`,
        price: p.price,
        priceCurrency: "BRL",
        url: p.hrefM,
        availability: "https://schema.org/InStock",
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Base
  title="Notifiquei — Automação de Instagram pela API oficial da Meta"
  description="O Notifiquei responde DMs, comentários e stories no Instagram em segundos, com a sua voz, pela API oficial da Meta. Você cria. Ele converte."
  path="/"
  jsonLd={jsonLd}
  heroPoster="/assets/hero-poster.webp"
>
  <Nav />

  <main>
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="hero__bg" aria-hidden="true"></div>
      <div class="container hero__inner">
        <div class="hero__copy">
          <span class="hero__badge"><span class="hero__badge-ic" aria-hidden="true">✦</span> Comece grátis · sem cartão</span>
          <span class="eyebrow is-plain hero__eyebrow">Instagram + TikTok · API oficial</span>
          <h1 class="hero__title">
            Eles comentam. <br class="br-r" />A gente <span class="hl">vende</span>.
          </h1>
          <p class="lead hero__lead">
            Para criadores e lojas que vendem pelo Instagram: o Notifiquei responde
            comentários, DMs e stories na hora — com a <em>sua</em> voz, pela API oficial da Meta.
            Você cria. Ele converte.
          </p>
          <div class="hero__actions">
            <a href="#planos" class="btn btn--brand btn--lg">Começar grátis<span class="arr" aria-hidden="true">→</span></a>
          </div>
          <div class="hero__proof">
            <span class="hero__avatars" aria-hidden="true">
              <img src="/assets/creators/c1-nutri.webp" alt="" width="40" height="40" loading="lazy" />
              <img src="/assets/creators/c3-beleza.webp" alt="" width="40" height="40" loading="lazy" />
              <img src="/assets/creators/c6-moda.webp" alt="" width="40" height="40" loading="lazy" />
              <img src="/assets/creators/c2-fitness.webp" alt="" width="40" height="40" loading="lazy" />
            </span>
            <span class="hero__proof-txt"><strong>+2.000 criadores</strong> já vendem no automático · pela API oficial da Meta</span>
          </div>
        </div>

        <!-- Cartão de automação ao vivo (peça-assinatura) -->
        <div class="hero__demo" role="img" aria-label="Demonstração de uma automação respondendo um comentário e fechando a venda">
          <video
            class="hero__video"
            src="/assets/hero.mp4"
            poster="/assets/hero-poster.webp"
            data-autoplay
            muted
            loop
            playsinline
            preload="none"
            aria-hidden="true"
          ></video>
        </div>
      </div>
    </section>

    <!-- ============ PROVA SOCIAL ============ -->
    <section class="proof">
      <div class="container">
        <div class="proof__stats">
          <div>
            <span class="proof__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg></span>
            <span class="proof__num">3s</span><span class="proof__lbl">tempo médio de resposta</span>
          </div>
          <div>
            <span class="proof__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg></span>
            <span class="proof__num">24h</span><span class="proof__lbl">vendendo, mesmo dormindo</span>
          </div>
          <div>
            <span class="proof__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 9.3 9.3 0 0 1-4-.9L3 20l1.3-4.3A8.4 8.4 0 0 1 3 11.5 8.4 8.4 0 0 1 12 3a8.4 8.4 0 0 1 9 8.5z"/></svg></span>
            <span class="proof__num">98%</span><span class="proof__lbl">dos comentários respondidos</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ AFILIADOS (subido pra perto do topo) ============ -->
    <section class="section affil" id="afiliados">
      <div class="container affil__inner">
        <div class="affil__copy reveal">
          <span class="eyebrow is-plain">Para afiliados</span>
          <h2 class="affil__title">Afiliado de Shopee, Mercado Livre e Amazon?<br class="br-r" /> Seu link no DM, <span class="hl">no automático</span>.</h2>
          <p class="lead">Posta o produto, pede pra comentarem a palavra-chave, e o Notifiquei manda o <strong>seu link de afiliado</strong> no direct de cada pessoa — na hora, sem você copiar e colar link o dia inteiro.</p>
          <a href="#planos" class="btn btn--brand btn--lg">Começar grátis<span class="arr" aria-hidden="true">→</span></a>
        </div>

        <div class="affil__demo reveal" aria-hidden="true">
          <div class="afcard afcard--comment">
            <span class="afcard__ava">J</span>
            <div class="afcard__who"><b>joana_ofertas</b> comentou<br /><span class="afcard__txt">"quero o link! 🔗"</span></div>
          </div>
          <div class="afcard__arrow"><span>resposta automática na hora</span></div>
          <div class="afcard afcard--dm">
            <div class="afcard__dm-top"><span class="afcard__ava afcard__ava--brand">N</span> Direct</div>
            <p class="afcard__bubble">Oi! 💕 Seu link tá aqui, é só tocar 👇</p>
            <span class="afcard__link">🔗 shopee.com.br/seu-link-de-afiliado</span>
          </div>
        </div>
      </div>

      <div class="container affil__marks reveal">
        <span class="affil__marks-label">Funciona com os links de afiliado de</span>
        <div class="affil__logos">
          <img src="/assets/marketplaces/shopee.svg" alt="Shopee" loading="lazy" />
          <img src="/assets/marketplaces/mercadolivre.svg" alt="Mercado Livre" loading="lazy" />
          <img src="/assets/marketplaces/amazon.svg" alt="Amazon" loading="lazy" />
          <img src="/assets/marketplaces/aliexpress.svg" alt="AliExpress" loading="lazy" />
          <img src="/assets/marketplaces/magalu.svg" alt="Magalu" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ CRIADORES (faces) ============ -->
    <CreatorsMarquee />

    <!-- ============ COMO FUNCIONA ============ -->
    <section class="section section--paper2" id="como">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Como funciona</span>
          <h2>Três passos. <br class="br-r" />Cinco minutos. Zero código.</h2>
          <p class="lead">Você não precisa de dev, time técnico ou tutorial de duas horas. Se a gente soubesse que era tão simples, teria cobrado mais caro.</p>
        </div>
        <div class="como__split">
          <ol class="steps steps--stack">
            {steps.map((s, i) => (
              <li class="step reveal" style={`--reveal-delay:${i * 90}ms`}>
                <span class="step__n">{s.n}</span>
                <h3 class="step__title">{s.title}</h3>
                <p class="step__body">{s.body}</p>
              </li>
            ))}
          </ol>
          <div class="como__media reveal">
            <div class="cdemo" aria-hidden="true">
              <div class="cdemo__bar">
                <span class="cdemo__dots"><i></i><i></i><i></i></span>
                <span class="cdemo__rail">
                  <b class="is-on" data-dot="0">01</b><b data-dot="1">02</b><b data-dot="2">03</b>
                </span>
              </div>
              <div class="cdemo__screen">
                <!-- 01 · Conecte -->
                <div class="cstage is-on" data-stage="0">
                  <span class="cstage__kicker">Conexão oficial</span>
                  <div class="cacct">
                    <span class="cacct__av"></span>
                    <span class="cacct__id"><b>@sua.loja</b><small>Instagram · via Meta</small></span>
                    <span class="cacct__ok">✓</span>
                  </div>
                  <div class="cline"><span class="cline__dot"></span>Sem senha exposta</div>
                  <div class="cline"><span class="cline__dot"></span>Login em poucos cliques</div>
                  <div class="cbtn">Conectado <span class="cbtn__ck">✓</span></div>
                </div>
                <!-- 02 · Gatilhos -->
                <div class="cstage" data-stage="1">
                  <span class="cstage__kicker">Novo gatilho</span>
                  <div class="crule">
                    <span class="crule__lbl">Quando comentarem</span>
                    <span class="crule__chip">"quero"</span>
                  </div>
                  <span class="crule__arrow">↓</span>
                  <div class="crule crule--do">
                    <span class="crule__lbl">Responder no Direct</span>
                    <span class="cswitch"><i></i></span>
                  </div>
                  <div class="cchips">
                    <span>DM recebido</span><span>Resposta de story</span><span class="cchips__more">+4</span>
                  </div>
                </div>
                <!-- 03 · Venda -->
                <div class="cstage" data-stage="2">
                  <div class="cmsg cmsg--in">quero!! 🔥</div>
                  <div class="cmsg cmsg--out">Oi! Seu link com desconto 👉 <b>notifiquei.me/promo</b></div>
                  <div class="ctoast"><span class="ctoast__ic">✓</span> Lead qualificado · link enviado</div>
                </div>
              </div>
            </div>
            <span class="como__cap"><span class="como__cap-dot"></span> Você monta. Ele cuida do resto.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ VEJA EM AÇÃO ============ -->
    <section class="section inaction">
      <div class="container inaction__inner">
        <div class="inaction__copy">
          <div class="section-head reveal">
            <span class="eyebrow">Veja em ação</span>
            <h2>Um comentário vira <br class="br-r" />venda em segundos.</h2>
            <p class="lead">A mesma pergunta, dois finais. No Instagram, quem responde primeiro fica com o cliente — e o Notifiquei garante que esse seja você.</p>
          </div>
          <div class="outcomes reveal">
            <div class="outcome outcome--lose">
              <span class="outcome__tag">Sem Notifiquei</span>
              <b>🥲 Venda perdida em 6 horas</b>
            </div>
            <div class="outcome outcome--win">
              <span class="outcome__tag">Com Notifiquei</span>
              <b>🎉 Venda fechada em 1 minuto</b>
            </div>
          </div>
        </div>
        <div class="inaction__video reveal">
          <video
            class="conversa-video"
            src="/assets/demo-conversa.mp4"
            poster="/assets/demo-conversa-poster.webp"
            data-autoplay muted loop playsinline preload="none" aria-hidden="true"
          ></video>
        </div>
      </div>
    </section>

    <!-- ============ UM DIA COMUM (split pinned) ============ -->
    <DayInLife />

    <!-- ============ DENTRO DA PLATAFORMA ============ -->
    <PlatformShowcase />

    <!-- ============ ZOOM (scroll travado) — separado da DayInLife pela Plataforma ============ -->
    <ZoomReveal />

    <!-- ============ CAPACIDADES ============ -->
    <Capabilities />

    <!-- ============ CTA DO MEIO ============ -->
    <section class="section midcta">
      <div class="container container--narrow midcta__inner reveal">
        <span class="eyebrow is-plain">Pronto quando você estiver</span>
        <h2 class="midcta__title">Quem responde primeiro <br class="br-r" />leva a venda. Que tal <span class="hl">ser você</span>?</h2>
        <div class="midcta__actions">
          <a href="#planos" class="btn btn--brand btn--lg">Começar grátis<span class="arr" aria-hidden="true">→</span></a>
        </div>
        <p class="midcta__sub">Grátis pra sempre · sem cartão</p>
      </div>
    </section>

    <!-- ============ POR QUE API OFICIAL ============ -->
    <section class="section section--ink on-ink risk">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Por que API oficial importa</span>
          <h2>Você já foi punido por usar ferramenta não-oficial.<br class="br-r" />Aqui, isso não existe.</h2>
          <p class="lead" style="color:var(--on-ink-soft)">Menos alcance, anúncio até 3× mais caro, conta banida — é o preço de automação que a Meta proíbe. O Notifiquei é 100% API oficial: você vende sem arriscar seu perfil.</p>
        </div>
        <div class="risk__grid">
          <article class="risk__card risk__card--bad reveal">
            <h3 class="risk__title">⚠ Ferramentas não-oficiais</h3>
            <ul class="risk__list">
              <li>Punições silenciosas — menos alcance, menos visualizações</li>
              <li>Anúncios até 3× mais caros depois de uma punição</li>
              <li>Risco real de banimento temporário ou permanente</li>
              <li>Acesso revogado sem aviso prévio</li>
            </ul>
          </article>
          <article class="risk__card risk__card--good reveal" style="--reveal-delay:120ms">
            <h3 class="risk__title">✓ Com Notifiquei (API oficial)</h3>
            <ul class="risk__list">
              <li>Integração 100% aprovada pela Meta — dentro das regras</li>
              <li>Sem risco de punição, banimento ou perda de alcance</li>
              <li>Suas métricas e anúncios seguem normais</li>
              <li>Atualiza sozinho quando a Meta muda as regras</li>
            </ul>
          </article>
        </div>
        <p class="risk__seal reveal">
          <span class="risk__seal-dot"></span> Notifiquei é parceiro certificado da Meta. Cada automação aqui está dentro das regras — e seu perfil fica protegido enquanto você vende.
        </p>
      </div>
    </section>

    <!-- ============ DEPOIMENTOS ============ -->
    <section class="section section--ink on-ink testi">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Quem já usa</span>
          <h2>Criadores reais. <br class="br-r" />Resultados reais.</h2>
        </div>
        <figure class="quote reveal">
          <blockquote>
            “Antes eu perdia vários comentários porque não conseguia responder rápido. Hoje o Notifiquei faz isso por mim e eu só falo com quem já quer comprar. Muito mais simples e acessível que o ManyChat.”
          </blockquote>
          <figcaption>
            <span class="tcard__ava" data-initial="L"></span>
            <span class="quote__who"><strong>Leid Medeiros</strong><span>@leidconsultoria</span></span>
          </figcaption>
        </figure>

        {/* PLACEHOLDER: confirmar/substituir pelas palavras reais dos clientes */}
        <div class="tgrid reveal">
          <figure class="tcard">
            <blockquote>“A gente vivia perdendo venda no comentário porque não dava conta de responder todo mundo a tempo. Agora chega um ‘quero’ e o cliente já recebe o link no direct na hora. Foi o pulo do gato pra gente.”</blockquote>
            <figcaption><span class="tcard__ava" data-initial="G"></span><span class="tcard__who"><strong>Gummy</strong><span>@gummy</span></span></figcaption>
          </figure>
          <figure class="tcard">
            <blockquote>“O que me convenceu foi não parecer robô. Configurei a resposta do meu jeito e meu público nem desconfia que não sou eu ali. Voltei a ter tempo pra gravar em vez de ficar grudado no direct.”</blockquote>
            <figcaption><span class="tcard__ava" data-initial="S"></span><span class="tcard__who"><strong>Sucesso na Rede</strong><span>@sucessonarede</span></span></figcaption>
          </figure>
          <figure class="tcard">
            <blockquote>“Achei que ia ser complicado de montar e em uns 5 minutos já tava rodando. O cliente comenta no post e recebe o orçamento na DM sozinho. Pra quem vende todo dia, isso é ouro.”</blockquote>
            <figcaption><span class="tcard__ava" data-initial="B"></span><span class="tcard__who"><strong>Sul Battery</strong><span>@sulbattery</span></span></figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ MARCAS (logo wall) ============ -->
    <section class="logostrip">
      <div class="container">
        <p class="logostrip__label reveal">Marcas e criadores que já usam</p>
        <div class="logos reveal" aria-label="Marcas que usam o Notifiquei">
          <div class="logos__track">
            {[...clientes, ...clientes, ...clientes].map((file) => (
              <img class="logos__item" src={`/assets/clientes/${file}`} alt={`${file.replace(/\.(png|svg|jpg)$/, "").replace(/-/g, " ")} — usa o Notifiquei`} loading="lazy" width={logoDims[file]} height={30} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ COMPARATIVO DE PREÇOS ============ -->
    <section class="section section--paper2 compare" id="comparativo">
      <div class="container">
        <div class="section-head section-head--center reveal">
