  <script>
    // Toggle mensal/anual nos planos
    const toggle = document.getElementById("billtoggle");
    const grid = document.getElementById("plans-grid");
    if (toggle && grid) {
      toggle.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".billtoggle__opt");
        if (!btn) return;
        const annual = btn.dataset.cycle === "a";
        toggle.querySelectorAll(".billtoggle__opt").forEach((o) => o.classList.toggle("is-on", o === btn));
        grid.querySelectorAll<HTMLElement>(".plan").forEach((card) => {
          const amt = card.querySelector<HTMLElement>(".plan__amount");
          const bill = card.querySelector<HTMLElement>(".plan__bill");
          const cta = card.querySelector<HTMLAnchorElement>(".plan__cta");
          if (amt) amt.textContent = annual ? amt.dataset.a! : amt.dataset.m!;
          if (bill) bill.textContent = annual ? bill.dataset.bill! : "";
          if (cta) cta.href = annual ? cta.dataset.hrefA! : cta.dataset.hrefM!;
        });
      });
    }

    // ===== Como funciona: demo da plataforma sincronizada ao scroll =====
    const como = document.getElementById("como");
    if (como) {
      const stages = Array.from(como.querySelectorAll<HTMLElement>(".cstage"));
      const dots = Array.from(como.querySelectorAll<HTMLElement>(".cdemo__rail b"));
      const stepEls = Array.from(como.querySelectorAll<HTMLElement>(".step"));
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let active = -1;
      const setStage = (i: number) => {
        if (i === active || i < 0 || i >= stages.length) return;
        active = i;
        stages.forEach((s, k) => s.classList.toggle("is-on", k === i));
        dots.forEach((d, k) => d.classList.toggle("is-on", k <= i));
      };

      const desktop = window.matchMedia("(min-width: 880px)");
      let cycle: number | undefined;
      const startCycle = () => {
        if (cycle || reduce) return;
        cycle = window.setInterval(() => setStage((active + 1) % stages.length), 2200);
      };
      const stopCycle = () => { if (cycle) { clearInterval(cycle); cycle = undefined; } };

      if ("IntersectionObserver" in window) {
        // passos cruzando o centro da viewport trocam o estágio (desktop)
        const stepIo = new IntersectionObserver(
          (entries) => {
            if (!desktop.matches) return;
            entries.forEach((e) => { if (e.isIntersecting) setStage(stepEls.indexOf(e.target as HTMLElement)); });
          },
          { rootMargin: "-48% 0px -48% 0px", threshold: 0 }
        );
        stepEls.forEach((s) => stepIo.observe(s));

        // no mobile (passos acima da demo) a demo gira sozinha enquanto visível
        const demoIo = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (desktop.matches) return;
            if (e.isIntersecting) startCycle(); else stopCycle();
          }),
          { threshold: 0.4 }
        );
        const demoEl = como.querySelector(".cdemo");
        if (demoEl) demoIo.observe(demoEl);
      }
      setStage(0);

      // lavagem rosa: intensidade = o quão centralizada a seção está na viewport
      if (!reduce) {
        let ticking = false;
        const update = () => {
          ticking = false;
          const r = como.getBoundingClientRect();
          const vh = window.innerHeight || 1;
          const center = r.top + r.height / 2;
          const dist = Math.abs(center - vh / 2) / vh; // 0 = centralizado
          como.style.setProperty("--cp", String(Math.max(0, 1 - dist * 1.6).toFixed(3)));
        };
        const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll, { passive: true });
        update();
      }
    }
  </script>
