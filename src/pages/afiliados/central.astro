  <script>
    // ---- Busca: filtra funções e dúvidas ao vivo ----
    const norm = (s) => (s || "").toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
    const input = document.getElementById("central-search");
    const items = Array.from(document.querySelectorAll("[data-search]"));
    const groups = Array.from(document.querySelectorAll("[data-group]"));
    const empties = Array.from(document.querySelectorAll("[data-empty]"));

    function sectionOf(el) {
      const sec = el.closest("section[id]");
      return sec ? sec.id : "";
    }

    function applyFilter(raw) {
      const q = norm(raw).trim();
      items.forEach((el) => {
        const match = !q || (el.getAttribute("data-search") || "").includes(q);
        el.classList.toggle("is-hidden", !match);
      });
      // esconde grupos/cabeçalhos sem nenhum item visível
      groups.forEach((g) => {
        if (g.hasAttribute("data-search")) return; // item, não grupo
        const visible = g.querySelector("[data-search]:not(.is-hidden)");
        const isItselfSearchable = g.matches("[data-search]");
        if (!isItselfSearchable) g.classList.toggle("is-hidden", !!q && !visible);
      });
      // estado vazio por seção
      empties.forEach((e) => {
        const id = e.getAttribute("data-empty");
        const anyVisible = items.some((el) => sectionOf(el) === id && !el.classList.contains("is-hidden"));
        e.hidden = !q || anyVisible;
      });
    }

    if (input) {
      input.addEventListener("input", () => applyFilter(input.value));
      input.addEventListener("search", () => applyFilter(input.value));
    }

    // ---- Copiar pitch ----
    const copyBtn = document.getElementById("pitch-copy");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        const text = copyBtn.getAttribute("data-text") || "";
        try {
          await navigator.clipboard.writeText(text);
          const old = copyBtn.textContent;
          copyBtn.textContent = "Copiado ✓";
          copyBtn.classList.add("is-done");
          setTimeout(() => { copyBtn.textContent = old; copyBtn.classList.remove("is-done"); }, 1800);
        } catch {
          copyBtn.textContent = "Selecione e copie";
        }
      });
    }

    // ---- Scrollspy nos chips da TOC ----
    const chips = Array.from(document.querySelectorAll(".toc__chip"));
    const targets = chips
      .map((c) => document.querySelector(c.getAttribute("href")))
      .filter(Boolean);
    if (targets.length && "IntersectionObserver" in window) {
      const spy = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            chips.forEach((c) => c.classList.toggle("is-on", c.getAttribute("href") === "#" + id));
          }
        });
      }, { rootMargin: "-45% 0px -50% 0px", threshold: 0 });
      targets.forEach((t) => spy.observe(t));
    }
  </script>
