---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import FinalCta from "../../components/FinalCta.astro";

// Normaliza texto pra busca (minúsculo + sem acento), usado nos data-search.
const norm = (s: string) => s.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");

const WPP = "https://wa.me/551231995949";
const YT = "https://www.youtube.com/@notifiqueicombr";
const FREE = "https://app.notifiquei.com.br/auth";

// Pitch pronto pra copiar (voz natural, sem cacoete de copy).
const pitch =
  "O Notifiquei responde os comentários e as DMs do seu Instagram automaticamente, na sua voz, pela API oficial da Meta — então não tem risco de bloqueio. Alguém comenta “quero” num post e em segundos recebe no direct o link, o preço, o que você quiser. Funciona também no TikTok, no mesmo plano. Dá pra testar de graça e custa a partir de R$ 99 por mês, preço fixo em real — diferente do ManyChat, que cobra por contato e em dólar.";

// Os 3 ganchos de venda.
const ganchos = [
  { t: "Zero risco de bloqueio", d: "É a API oficial da Meta, não automação disfarçada. O cliente não corre risco de tomar bloqueio." },
  { t: "Preço fixo em real", d: "R$ 99 por mês não importa quantos contatos. O ManyChat e o Gaio cobram por contato — a conta sobe junto com a audiência." },
  { t: "Instagram + TikTok juntos", d: "Cada conta do plano já conecta um Instagram e um TikTok. O cliente automatiza os dois sem pagar a mais." },
];

// Planos — só MENSAL (a comissão de afiliado hoje é nos planos mensais).
const planos = [
  {
    name: "Solo", price: "99", contas: "1 conta (Instagram + TikTok)",
    blurb: "Criador iniciante, operação pequena.",
    href: "https://pay.cakto.com.br/35rmdfj", featured: true,
    features: ["Automações ilimitadas", "Contatos ilimitados", "Templates completos", "Atendimento via chat", "Novidades antes de todo mundo"],
  },
  {
    name: "Pro", price: "499", contas: "5 contas (Instagram + TikTok)",
    blurb: "Pra quem já escalou um pouco.",
    href: "https://pay.cakto.com.br/52z4k9u", featured: false,
    features: ["Times e divisão por equipe", "Automações ilimitadas", "Contatos ilimitados", "Templates completos", "Atendimento via chat"],
  },
  {
    name: "Business", price: "799", contas: "10 contas (Instagram + TikTok)",
    blurb: "Agência e operação grande.",
    href: "https://pay.cakto.com.br/3e8f2ba", featured: false,
    features: ["Times e divisão por equipe", "Automações ilimitadas", "Contatos ilimitados", "Templates completos", "Atendimento VIP prioritário"],
  },
];

// Comparativo curto vs concorrentes (jun/2026, tabelas públicas).
const compara = [
  { f: "Preço por mês", mc: "R$ 249 a R$ 4.309 (em dólar)", ga: "R$ 74,90 a R$ 3.774", us: "R$ 99 fixo" },
  { f: "Contatos ilimitados", mc: false, ga: false, us: true },
  { f: "Preço fixo em real", mc: false, ga: true, us: true },
  { f: "Instagram + TikTok no mesmo plano", mc: false, ga: false, us: true },
  { f: "App nativo (iPhone e Android)", mc: false, ga: false, us: true },
  { f: "Sorteios pelos comentários", mc: false, ga: false, us: true },
  { f: "Suporte e produto em português", mc: false, ga: true, us: true },
];

// ===== Funções do Instagram (inventário + "por que vende") =====
const funcoesIG = [
  { area: "Gatilhos — o que dispara a automação", itens: [
    { n: "Mensagem na DM", v: "Responde quem chama no direct sem o cliente ficar grudado no celular." },
    { n: "Comentário em post", v: "Comentou “quero”? Vira conversa no direct na hora, antes do lead esfriar." },
    { n: "Resposta a story", v: "Quem responde o story já entra num fluxo de venda automático." },
    { n: "Comentário em live", v: "Durante a live a galera comenta e recebe o link no direct sozinha." },
    { n: "Botão de quebra-gelo no menu", v: "Dá um atalho pronto no direct pra pessoa começar a conversa." },
    { n: "Campanha (envio em massa)", v: "Dispara pra uma lista segmentada quando o cliente quiser reativar a base." },
    { n: "Filtros por palavra-chave e por post", v: "A automação só dispara onde e quando faz sentido, sem bagunçar os outros posts." },
    { n: "Condição “é seguidor?”", v: "Trata seguidor e não-seguidor de formas diferentes — dá pra pedir o follow antes de entregar." },
    { n: "Condição “tem a etiqueta X?”", v: "Mostra caminhos diferentes pra quem já é cliente e pra quem é lead novo." },
  ]},
  { area: "Ações de mensagem", itens: [
    { n: "Texto, imagem, áudio e vídeo", v: "Manda no formato que mais converte, não só texto seco." },
    { n: "Card (imagem + título + botão)", v: "Mostra o produto com cara de loja e um botão de comprar." },
    { n: "Carrossel de cards", v: "Apresenta vários produtos numa mensagem só, deslizando." },
    { n: "Botões e respostas rápidas", v: "O lead escolhe no toque e o fluxo segue sozinho." },
    { n: "Responder comentário automaticamente", v: "Responde em público e ainda puxa a pessoa pro direct." },
    { n: "Perguntar e salvar a resposta", v: "Coleta nome, e-mail ou o que precisar dentro da conversa." },
  ]},
  { area: "Construtor de automações", itens: [
    { n: "Editor visual em blocos + modo guiado", v: "Monta o fluxo arrastando blocos, sem código — ou no modo simples passo a passo." },
    { n: "Ativar, pausar, duplicar e validar", v: "Testa, clona e ajusta uma automação em segundos." },
    { n: "Histórico de execuções", v: "Mostra o que disparou e se deu certo." },
    { n: "Esperas: fixa, aleatória e agendada", v: "Programa follow-up pra horas ou dias depois." },
    { n: "Etiquetar pela automação", v: "Organiza o contato sozinho conforme ele reage." },
    { n: "Pastas de automação", v: "Mantém dezenas de fluxos organizados." },
    { n: "Assistente de IA que monta o fluxo (beta)", v: "Descreve o que quer e a IA monta o rascunho." },
    { n: "Biblioteca de templates", v: "Começa de um modelo pronto em vez do zero." },
  ]},
  { area: "Atendimento e Inbox", itens: [
    { n: "Caixa de entrada das DMs", v: "Todas as conversas num lugar só." },
    { n: "Responder manual, com histórico e busca", v: "Assume a conversa quando quiser, com todo o contexto na mão." },
    { n: "Pausar e retomar a IA no meio", v: "Entra no manual e devolve pra IA sem perder o fio." },
  ]},
  { area: "Comentários", itens: [
    { n: "Listar e filtrar comentários (posts e lives)", v: "Acompanha tudo que comentaram sem ficar rolando o feed." },
    { n: "Responder, auto-responder e ocultar", v: "Responde rápido e esconde o que for spam ou ataque." },
    { n: "Análise de sentimento", v: "Vê na hora se o comentário é elogio ou reclamação." },
  ]},
  { area: "Quebra-gelos", itens: [
    { n: "Criar, editar e reordenar (até 4)", v: "Coloca atalhos no direct que já puxam a conversa pro lado da venda." },
  ]},
  { area: "Inteligência Artificial (add-on)", itens: [
    { n: "Agente de IA (Gemini, GPT ou Sonnet)", v: "Responde sozinho, na voz do criador, a qualquer hora." },
    { n: "Base de conhecimento + memória", v: "A IA responde com as infos reais do negócio e lembra do papo." },
    { n: "Detecção de intenção de compra + alerta", v: "Avisa quando o lead está quente pra fechar na hora certa." },
  ]},
  { area: "Crescimento", itens: [
    { n: "Campanhas segmentadas por etiqueta", v: "Reativa a base inteira com uma mensagem certeira, agendada e com relatório." },
    { n: "Sorteios pelos comentários", v: "Coleta os @, sorteia e re-sorteia o vencedor num clique." },
  ]},
  { area: "Organização", itens: [
    { n: "Contatos com perfil e filtros", v: "Conhece quem fala com o perfil e segmenta fácil." },
    { n: "Etiquetas", v: "Marca lead, cliente, quente ou frio — e dispara diferente pra cada." },
    { n: "Exportar CSV", v: "Leva os contatos pra onde o cliente quiser." },
  ]},
  { area: "Análise", itens: [
    { n: "Painel de métricas", v: "Mostra mensagens, respostas e cliques num olhar." },
    { n: "Estatísticas por conta e automação", v: "Vê qual automação está vendendo e qual não." },
    { n: "Rastreamento de links + CTR", v: "Sabe exatamente o que foi clicado." },
    { n: "Analytics avançado: funil e conversão (add-on)", v: "Acompanha do comentário até a venda." },
  ]},
  { area: "Integrações", itens: [
    { n: "Webhook, n8n, FunilOnline e Responda.me", v: "Conecta o Notifiquei com o resto das ferramentas do cliente." },
  ]},
  { area: "Conta e Times", itens: [
    { n: "Conectar conta Business ou Creator", v: "Conecta pela Meta oficial, sem senha exposta." },
    { n: "Times com papéis (dono e membro)", v: "Agência gerencia vários clientes em painéis separados." },
    { n: "Mover conta entre times", v: "Reorganiza clientes sem refazer nada." },
    { n: "Assinaturas, add-ons e painel admin", v: "Controla plano, extras e notificações num lugar só." },
  ]},
];

// ===== Funções do TikTok (mais enxuto) =====
const funcoesTT = [
  { area: "Automações por palavra-chave", itens: [
    { n: "DM automática por palavra-chave", v: "Responde no direct do TikTok quando alguém manda a palavra combinada." },
    { n: "Correspondência: contém, igual ou começa com", v: "Decide com que precisão a palavra ativa a resposta." },
  ]},
  { area: "Mensagens automáticas", itens: [
    { n: "Resposta por palavra-chave", v: "Manda o link ou recado certo pra cada palavra." },
    { n: "Boas-vindas na primeira DM", v: "Recebe quem chega no direct com uma mensagem pronta." },
    { n: "Resposta padrão (fallback)", v: "Quando nada bate, ainda responde algo útil." },
  ]},
  { area: "Atendimento e contatos", itens: [
    { n: "Base de quem mandou DM", v: "Guarda quem já falou com o perfil." },
    { n: "Enviar texto na conversa", v: "Assume a conversa manualmente quando precisar." },
  ]},
  { area: "Conta e Times", itens: [
    { n: "Conectar conta de negócio", v: "Conecta o TikTok Business sem gastar uma vaga a mais." },
    { n: "Mesmo pool de vagas e acesso por time", v: "Uma vaga já cobre 1 Instagram + 1 TikTok." },
  ]},
];

// ===== Dúvidas e objeções (oficiais da LP + reais de cliente), agrupadas =====
const faqGrupos = [
  { tema: "Segurança e como funciona", itens: [
    { q: "Isso pode bloquear o Instagram do meu cliente?", a: "Não. O Notifiquei é provedor oficial da Meta e usa só a API oficial do Instagram. Não é automação disfarçada, então não há risco de banimento." },
    { q: "Precisa saber programar?", a: "Nada. Zero código. Quem sabe mandar mensagem no Instagram sabe usar — a interface é toda visual." },
    { q: "Ele responde sozinho, com IA?", a: "Sim. O agente de IA responde DMs e comentários na voz do criador, com uma base de conhecimento que você ensina, e lembra do contexto da conversa. Quando o lead esquenta, ele avisa pra você fechar." },
    { q: "Precisa de conta profissional ou de criador?", a: "Sim, uma conta Profissional ou de Criador no Instagram. É grátis de ativar, leva 1 minuto, e é exigência da própria API oficial da Meta." },
  ]},
  { tema: "Automação no Instagram", itens: [
    { q: "Dá pra mandar mensagem pra quem comentou mas não me segue?", a: "Dá. A janela de conversa abre quando a pessoa comenta. Você consegue enviar uma mensagem; pra mandar mais, ela precisa de uma segunda interação (clicar num botão, por exemplo)." },
    { q: "Por que depois do comentário só vai botão e não texto direto? Como mando a página de vendas?", a: "É uma definição da Meta pro primeiro contato. Mas dá pra mandar o texto junto do botão, e assim que a pessoa clica o fluxo segue livre — aí você manda link, imagem, o que quiser." },
    { q: "Tem DM automática de boas-vindas pra novo seguidor?", a: "Hoje não. É uma limitação técnica da Meta (chegou a liberar só pro ManyChat, que também está com problema). Sem previsão por enquanto." },
    { q: "Dá pra programar follow-up, tipo dois dias depois?", a: "Dá, desde que a pessoa tenha interagido. A janela é de 7 dias e basta colocar um nó de espera na automação." },
    { q: "Se a pessoa mandar a palavra-chave de novo, dispara outra vez?", a: "Só dispara de novo depois de 24 horas, pra não floodar quem já recebeu." },
    { q: "Consigo disparar pra quem comenta em anúncios, não só nos posts do feed?", a: "É o esperado, e está em ajuste fino. Provavelmente vai exigir conectar o login do Facebook. Se for decisivo pro seu lead, fala com a gente que confirmamos o status atual." },
    { q: "Dá pra disparar mensagem durante a live?", a: "Dá. Ele não responde dentro da live, mas responde no direct de quem comentou." },
  ]},
  { tema: "Sorteios", itens: [
    { q: "Dá pra fazer sorteio na própria plataforma?", a: "Dá. O Notifiquei salva os @ de quem participou pelos comentários, sorteia o vencedor e re-sorteia num clique. Você ativa por palavra-chave ou escolhendo o post." },
  ]},
  { tema: "Editor de fluxo e configuração", itens: [
    { q: "Como deleto ou duplico um nó? Posso ter mais de um gatilho?", a: "Delete apaga o nó e Ctrl+C / Ctrl+V duplica. Dá pra ter a mesma palavra ativando em story, DM e comentário — só monta uma automação separada pra cada gatilho." },
    { q: "Nas regras de moderação é palavra por palavra ou lista por vírgula? Onde vejo quem quer comprar?", a: "Pode separar as palavras por vírgula numa lista só. E quem demonstra intenção de compra aparece no Inbox." },
  ]},
  { tema: "Inteligência Artificial", itens: [
    { q: "Dá pra treinar a IA com o meu conteúdo e usar a minha própria chave de API?", a: "Por enquanto não. Hoje você ensina a IA por uma base de conhecimento dentro da plataforma. O treino com base no tom dos próprios comentários vem mais pra frente." },
  ]},
  { tema: "Contas, times e agência", itens: [
    { q: "Quero usar a ferramenta pro meu cliente. Crio um time e ele configura? Preciso da senha do Instagram dele?", a: "Você cria o time, configura e envia um convite. O cliente conecta o Instagram dele pela Meta, sem precisar passar senha pra ninguém." },
    { q: "No plano Solo dá pra dar um acesso separado pro cliente gerir?", a: "No Solo não — só compartilhando o login. Acesso separado por equipe vem a partir do Pro. O upgrade paga só a diferença de valor." },
    { q: "A conta do TikTok consome uma vaga separada da do Instagram? Dá pra montar fluxos no TikTok?", a: "Não consome vaga separada: uma vaga já cobre 1 Instagram + 1 TikTok. No TikTok hoje é só automação de DM por palavra-chave, sem o construtor visual de fluxos." },
    { q: "Funciona pra e-commerce?", a: "Funciona. Tem cliente vendendo moda, cosméticos, suplementos e produtos físicos em geral. O fluxo ideal muda um pouco e tem template pronto pra isso." },
    { q: "Funciona com TikTok?", a: "Sim. O Notifiquei automatiza as DMs do TikTok (conta Business), e cada plano já conecta 1 Instagram + 1 TikTok pelo mesmo preço." },
  ]},
  { tema: "Conta e login", itens: [
    { q: "Meu cliente não consegue acessar (e-mail ou senha inválidos). Como resolve?", a: "Quase sempre é a URL: o acesso é em app.notifiquei.com.br. O código de login expira rápido, então é só pedir um novo. Se persistir, o suporte resolve no privado." },
    { q: "Já tinha conta na versão antiga. Perco tudo?", a: "As contas e a assinatura continuam valendo, mas é preciso revincular os Instagrams, porque a Meta exige um novo vínculo. A versão antiga foi descontinuada." },
    { q: "Reautentiquei e as automações sumiram. É normal?", a: "Isso foi ajustado: os tokens agora se atualizam sem forçar reconexão, então não some mais." },
  ]},
  { tema: "Integrações e o que vem por aí", itens: [
    { q: "Tem API ou webhook pra puxar as mensagens, tipo um alerta no Slack?", a: "Tem. Já existe webhook em perguntas e respostas, e o push por intenção de compra está implementado." },
    { q: "Dá pra integrar com checkout (Kiwify, Hotmart, Cakto, Greenn) e rastrear as vendas?", a: "Sim, está em configuração, com um dashboard que acompanha do contato até a venda." },
    { q: "Vai ter WhatsApp, marketplaces ou agendamento em outras redes?", a: "WhatsApp talvez, pela API oficial. Marketplaces é mais difícil. Outras redes, sem promessa por enquanto." },
  ]},
  { tema: "Agendamento de posts", itens: [
    { q: "O Notifiquei agenda Reels, posts, carrossel e stories ou só automação? Dá pra agendar com música e link no story?", a: "Agenda tudo isso. Áudio em Reels (precisa conectar a conta de negócio) e música no carrossel são próximas etapas. Link no story está em estudo, porque depende da Meta." },
  ]},
  { tema: "Planos, preço e garantia", itens: [
    { q: "Qual a diferença pro ManyChat?", a: "Mais barato, suporte em português, interface mais simples e foco no Brasil. E o preço é fixo em real — o ManyChat cobra por contato e em dólar, então a conta sobe com a audiência." },
    { q: "Funciona com poucos seguidores?", a: "Funciona com conta de qualquer tamanho. Quem responde rápido vende mais, tendo 500 ou 500 mil seguidores. Conta menor costuma sentir o resultado primeiro." },
    { q: "Pode cancelar quando quiser?", a: "Pode, sem fidelidade, direto pelo painel. E todo plano pago tem garantia de 7 dias: se não rolar, devolvemos 100% do valor." },
    { q: "Vai rolar promoção ou plano vitalício?", a: "Vitalício não temos mais. O que vem são planos anuais com valores bem agressivos." },
  ]},
  { tema: "Tutoriais e suporte", itens: [
    { q: "Tem vídeos tutoriais?", a: "Tem, no canal do YouTube (@notifiqueicombr). E pra qualquer dúvida o suporte ajuda direto." },
  ]},
];

// Perfis que vendem bem (apoio pro afiliado).
const perfis = [
  { t: "Infoprodutor", d: "Vende curso ou mentoria pra quem também vende no Instagram. A indicação vira escala natural pros dois lados." },
  { t: "Consultor de marketing", d: "Atende cliente que precisa automatizar o Instagram. Em vez de montar do zero, indica e recebe todo mês." },
  { t: "Agência digital", d: "Gerencia o Instagram de vários clientes. Cada conta nova rende 40% do plano, de forma recorrente." },
  { t: "Influencer de marketing", d: "Fala de vendas, copy e tráfego. A audiência precisa de ferramenta prática — você indica e lucra." },
  { t: "Gestor de tráfego", d: "Toca anúncio de lançamento e o Notifiquei responde o lead que veio do ad. Você ganha dos dois lados." },
  { t: "Comunidade ou grupo", d: "Lidera grupo no Telegram, WhatsApp ou Discord. A recomendação tem peso — dá pra monetizar sem perder a confiança." },
];

// ---- SEO ----
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Central do afiliado Notifiquei",
    url: "https://notifiquei.com.br/afiliados/central",
    isPartOf: { "@id": "https://notifiquei.com.br/#org" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Notifiquei", item: "https://notifiquei.com.br/" },
      { "@type": "ListItem", position: 2, name: "Afiliados", item: "https://notifiquei.com.br/afiliados" },
      { "@type": "ListItem", position: 3, name: "Central do afiliado", item: "https://notifiquei.com.br/afiliados/central" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqGrupos.flatMap((g) => g.itens).map((f) => ({
      "@type": "Question",
