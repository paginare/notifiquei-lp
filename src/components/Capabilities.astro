---
interface Props {
  bg?: "paper" | "paper2";
  eyebrow?: string;
  title?: string; // pode conter <br>
  lead?: string;
}
const {
  bg = "paper2",
  eyebrow = "O que você ganha",
  title = "Tudo que o Notifiquei <br class='br-r' /><span class='hl'>faz por você</span>.",
  lead = "Nada de funcionalidade que você nunca vai usar. A gente colocou só o que te ajuda a vender — e cortou todo o resto.",
} = Astro.props;

const caps = [
  { t: "Comentário → DM → venda", d: "Alguém comenta “quero”. Ele puxa pro privado, manda o link, qualifica e te avisa só na hora de fechar." },
  { t: "Agente de IA com a sua voz", d: "Responde DMs e comentários sozinho, na sua voz, com a base que você ensina e memória da conversa — sem parecer robô." },
  { t: "Funil que qualifica sozinho", d: "Perguntas inteligentes, respostas salvas, exportação pro CRM. Você fala só com quem já quer comprar." },
  { t: "Moderação com IA", d: "Esconde spam, ofensa e negatividade antes de qualquer seguidor ver — e responde os comentários bons sozinho." },
  { t: "Sorteios pelos comentários", d: "Quem comenta a palavra entra no sorteio automaticamente. Você clica e a gente sorteia — sem caçar comentário." },
  { t: "Times e agência", d: "Múltiplas contas, equipe organizada, acessos separados. Ideal pra quem gerencia várias marcas." },
  { t: "TikTok DM automático", d: "Boas-vindas, palavras-chave e resposta padrão no TikTok Business — ninguém fica sem retorno." },
  { t: "Controle pelo celular", d: "App nativo no iPhone e Android: crie, pause e acompanhe suas automações de onde estiver." },
];
---
<section class={`section ${bg === "paper2" ? "section--paper2" : ""}`}>
  <div class="container">
    <div class="section-head section-head--center reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h2 set:html={title} />
      <p class="lead">{lead}</p>
    </div>
    <div class="caps">
      {caps.map((c, i) => (
        <article class="cap reveal" style={`--reveal-delay:${(i % 4) * 70}ms`}>
          <span class="cap__n">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="cap__title">{c.t}</h3>
          <p class="cap__body">{c.d}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .caps { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 3rem; }
  /* cards off-white, distintos e numerados */
  .cap { background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 1.6rem; box-shadow: var(--shadow-sm); transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out); }
  .cap:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .cap__n { display: inline-block; font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; color: var(--brand-ink); letter-spacing: 0.12em; }
  .cap__title { margin-top: 0.7rem; font-size: 1.12rem; font-family: var(--font-display); font-weight: 700; letter-spacing: -0.01em; }
  .cap__body { margin-top: 0.6rem; color: var(--ink-soft); font-size: 0.93rem; line-height: 1.55; }
  @media (min-width: 640px) { .caps { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 980px) { .caps { grid-template-columns: repeat(4, 1fr); } }
</style>
