---
// Seção com scroll travado (pin) + zoom no painel do app (GSAP ScrollTrigger).
---
<section class="zoompin">
  <div class="zoompin__stage">
    <div class="zoompin__caps reveal">
      <p class="zoompin__cap" data-cap="1"><span class="eyebrow is-plain">Por dentro</span>Tudo num painel só.</p>
      <p class="zoompin__cap" data-cap="2"><span class="eyebrow is-plain">Em tempo real</span>E você vê cada lead quente chegar.</p>
    </div>

    <div class="zoompin__shot reveal" aria-hidden="true">
      <div class="appwin">
        <div class="appwin__bar"><span class="appwin__dots"><i></i><i></i><i></i></span><span class="appwin__url">notifiquei · painel</span></div>
        <div class="appwin__body">
          <div class="appwin__head">
            <div><b>Olá, Mariana 👋</b><small>aqui está o resumo de hoje</small></div>
            <span class="appwin__chip">Últimos 30 dias</span>
          </div>
          <div class="appwin__cards">
            <div class="acard">
              <div class="acard__head"><span>Seguidores ativos</span><span class="acard__ic"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg></span></div>
              <b class="acard__num">8.412</b><span class="acard__delta">+12% desde o último mês</span>
            </div>
            <div class="acard">
              <div class="acard__head"><span>Interações automáticas</span><span class="acard__ic"><svg viewBox="0 0 24 24"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span></div>
              <b class="acard__num">1.284</b><span class="acard__delta">+18% desde o último mês</span>
            </div>
            <div class="acard">
              <div class="acard__head"><span>Taxa de resposta</span><span class="acard__ic"><svg viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></span></div>
              <b class="acard__num">98%</b><span class="acard__delta">+3% desde o último mês</span>
            </div>
          </div>
          <div class="appwin__chart">
            <div class="appwin__chart-head"><b>Cliques no link</b><span>esta semana</span></div>
            <svg viewBox="0 0 600 150" preserveAspectRatio="none">
              <defs><linearGradient id="zg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="var(--brand)" stop-opacity="0.25"/><stop offset="1" stop-color="var(--brand)" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,120 C70,112 110,70 170,76 C230,82 270,38 340,46 C410,54 450,18 600,12 L600,150 L0,150 Z" fill="url(#zg)"/>
              <path d="M0,120 C70,112 110,70 170,76 C230,82 270,38 340,46 C410,54 450,18 600,12" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .zoompin { position: relative; }
  .zoompin__stage { height: 100vh; min-height: 640px; display: grid; place-items: center; overflow: hidden; position: relative; background: linear-gradient(180deg, var(--paper), var(--paper-2)); }
  .zoompin__caps { position: absolute; top: clamp(6rem, 14vh, 9.5rem); left: 0; right: 0; text-align: center; z-index: 3; pointer-events: none; }
  .zoompin__cap { position: absolute; left: 0; right: 0; display: flex; flex-direction: column; align-items: center; gap: 0.7rem; font-family: var(--font-display); font-weight: 800; letter-spacing: -0.03em; font-size: clamp(2.3rem, 1.3rem + 3.8vw, 4.75rem); line-height: 0.98; text-wrap: balance; }
  .zoompin__cap .eyebrow { color: var(--brand-ink); }
  .zoompin__cap[data-cap="2"] { opacity: 0; }

  .zoompin__shot { width: min(1120px, 94vw); will-change: transform; }
  .appwin { background: var(--card); border: 1px solid var(--line); border-radius: 20px; overflow: hidden; box-shadow: 0 12px 30px rgba(22,18,16,0.08), 0 50px 90px -30px rgba(22,18,16,0.32); }
  .appwin__bar { display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 1rem; border-bottom: 1px solid var(--line-soft); background: hsl(30 30% 99%); }
  .appwin__dots { display: inline-flex; gap: 6px; }
  .appwin__dots i { width: 10px; height: 10px; border-radius: 50%; background: var(--paper-3); border: 1px solid var(--line); }
  .appwin__url { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); }
  .appwin__body { padding: 1.25rem; }
  .appwin__head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
  .appwin__head b { font-size: 1.25rem; font-weight: 700; }
  .appwin__head small { display: block; font-size: 0.9rem; color: var(--ink-faint); }
  .appwin__chip { font-size: 0.75rem; font-weight: 600; color: var(--ink-soft); border: 1px solid var(--line); border-radius: var(--r-pill); padding: 0.35rem 0.8rem; white-space: nowrap; }
  .appwin__cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; }
  .acard { min-width: 0; background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 0.9rem; box-shadow: var(--shadow-sm); }
  .acard__head { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .acard__head span:first-child { font-size: 0.82rem; font-weight: 600; color: var(--ink-soft); }
  .acard__ic { flex: none; width: 30px; height: 30px; border-radius: 50%; background: var(--brand-wash); display: grid; place-items: center; }
  .acard__ic svg { width: 16px; height: 16px; fill: none; stroke: var(--brand-ink); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .acard__num { display: block; font-family: var(--font-display); font-weight: 800; font-size: 2.1rem; letter-spacing: -0.03em; margin-top: 0.55rem; line-height: 1; }
  .acard__delta { font-size: 0.66rem; color: var(--brand-ink); font-weight: 600; }
  .appwin__chart { margin-top: 0.9rem; background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 0.9rem 0.9rem 0; box-shadow: var(--shadow-sm); }
  .appwin__chart-head { display: flex; align-items: baseline; justify-content: space-between; }
  .appwin__chart-head b { font-size: 0.85rem; }
  .appwin__chart-head span { font-size: 0.72rem; color: var(--ink-faint); }
  .appwin__chart svg { width: 100%; height: 120px; display: block; }

  /* mobile e reduced-motion: layout estático (sem pin/zoom) */
  @media (prefers-reduced-motion: reduce), (max-width: 760px) {
    .zoompin__stage { height: auto; min-height: 0; padding: var(--space-section) var(--gutter); overflow: clip; }
    .zoompin__caps { position: static; margin-bottom: 2.25rem; }
    .zoompin__cap { position: static; font-size: clamp(1.9rem, 6vw, 2.6rem); }
    .zoompin__cap[data-cap="2"] { display: none; }
    .zoompin__shot { width: 100%; max-width: 460px; margin-inline: auto; }
    .appwin__cards { gap: 0.5rem; }
    .acard { padding: 0.7rem; }
    .acard__num { font-size: 1.3rem; }
    .acard__head span:first-child { font-size: 0.62rem; }
    .acard__delta { font-size: 0.58rem; }
    .appwin__head small { font-size: 0.72rem; }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const stage = document.querySelector<HTMLElement>(".zoompin__stage");

  if (stage && !reduce && window.innerWidth > 760) {
    const shot = stage.querySelector<HTMLElement>(".zoompin__shot");
    const caps = stage.querySelector<HTMLElement>(".zoompin__caps");
    const cap2 = stage.querySelector<HTMLElement>('[data-cap="2"]');
    const cap1 = stage.querySelector<HTMLElement>('[data-cap="1"]');

    gsap.set(shot, { scale: 0.86, transformOrigin: "50% 60%", autoAlpha: 1, clearProps: "filter" });
    gsap.set(caps, { scale: 0.82, transformOrigin: "50% 0%", autoAlpha: 1, clearProps: "filter" });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: stage,
        start: "top top",
        end: "+=160%",
        pin: true,
        scrub: 0.5,
        anticipatePin: 1,
      },
    });
    tl.to(shot, { scale: 1.16, ease: "none" }, 0);
    tl.to(caps, { scale: 1.14, ease: "none" }, 0);          // título vai crescendo
    tl.to(cap1, { autoAlpha: 0, ease: "none" }, 0.5);
    tl.fromTo(cap2, { autoAlpha: 0 }, { autoAlpha: 1, ease: "none" }, 0.52);
  }
</script>
