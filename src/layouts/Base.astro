---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  jsonLd?: object[];
  noindex?: boolean;
  canonicalPath?: string; // força o canonical p/ outra rota (ex.: variantes A/B → "/")
  heroPoster?: string; // pré-carrega o poster do vídeo do hero (LCP) quando informado
}

const {
  title = "Notifiquei — Automação de Instagram pela API oficial da Meta",
  description = "O Notifiquei responde DMs, comentários e stories no Instagram em segundos, com a sua voz, pela API oficial da Meta. Você cria. Ele converte.",
  path = "/",
  jsonLd = [],
  noindex = false,
  canonicalPath,
  heroPoster,
} = Astro.props;

const site = "https://www.notifiquei.com.br";
// home sem barra final, p/ casar com o sitemap (trailingSlash: never)
const canonicalTarget = canonicalPath ?? path;
const canonical = canonicalTarget === "/" ? site : site + canonicalTarget;
// ?v=2 força WhatsApp/Facebook a re-buscar a imagem (eles cacheiam por URL)
const ogImage = site + "/assets/og-image.jpg?v=2";
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <meta name="theme-color" content="#FBF7F0" />

  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/assets/favicon-32.png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/assets/favicon-180.png" />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Notifiquei" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Preload das fontes críticas -->
  <link rel="preload" href="/assets/fonts/bricolage-800.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/assets/fonts/jakarta-400.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Poster do hero como prioridade — preenche a área do hero cedo (melhora Speed Index) -->
  {heroPoster && <link rel="preload" href={heroPoster} as="image" fetchpriority="high" />}

  {jsonLd.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)} />
  ))}
</head>
<body>
  <div class="grain" aria-hidden="true"></div>
  <slot />

  <script>
    // Encaminha params de tracking da URL de ENTRADA (afiliado/anúncio) para os CTAs
    // de checkout Cakto e signup, sem pisar no que a pessoa já usa. Se a entrada traz
    // um param (ex.: src de afiliado), ele VENCE o nosso fallback (src=home/v2/v3).
    (() => {
      const TRACK_KEYS = ["src", "sck", "xcode", "utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term", "gclid", "fbclid", "ttclid", "gad_source"];
      const incoming = new URLSearchParams(window.location.search);
      const carry = TRACK_KEYS.filter((k) => incoming.get(k));
      if (!carry.length) return;
      const merge = (raw: string) => {
        try {
          const u = new URL(raw, window.location.origin);
          carry.forEach((k) => u.searchParams.set(k, incoming.get(k)!));
          return u.toString();
        } catch { return raw; }
      };
      const tracked = (h: string | null) => !!h && /pay\.cakto\.com\.br|app\.notifiquei\.com\.br\/auth/.test(h);
      document.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((a) => {
        const h = a.getAttribute("href");
        if (tracked(h)) a.setAttribute("href", merge(h!));
        if (a.dataset.hrefM) a.dataset.hrefM = merge(a.dataset.hrefM); // mensal (toggle)
        if (a.dataset.hrefA) a.dataset.hrefA = merge(a.dataset.hrefA); // anual (toggle)
      });
    })();

    // Reveal no scroll — robusto em todo navegador, respeita reduced-motion.
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Vídeos: preload="none" + data-autoplay. Só começam a carregar/tocar quando
    // entram na tela, e a observação só arranca quando a thread fica ociosa — assim
    // o vídeo não disputa banda nem main-thread com a fonte/LCP no carregamento inicial.
    // reduced-motion: ficam pausados, mostrando o poster.
    const vids = document.querySelectorAll<HTMLVideoElement>("video[data-autoplay]");
    if (!prefersReduced && vids.length) {
      const start = (v: HTMLVideoElement) => v.play().catch(() => {});
      if ("IntersectionObserver" in window) {
        const vio = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { start(e.target as HTMLVideoElement); obs.unobserve(e.target); }
          });
        }, { rootMargin: "200px 0px" });
        const kick = () => vids.forEach((v) => vio.observe(v));
        if ("requestIdleCallback" in window) (window as any).requestIdleCallback(kick, { timeout: 2000 });
        else window.addEventListener("load", () => setTimeout(kick, 200), { once: true });
      } else {
        vids.forEach(start);
      }
    }

    const els = document.querySelectorAll<HTMLElement>(".reveal");
    if (prefersReduced || !("IntersectionObserver" in window)) {
      els.forEach((el) => el.classList.add("in"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in");
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.12 }
      );
      els.forEach((el) => io.observe(el));
    }

    // Nav: sombra ao rolar
    const nav = document.querySelector(".nav");
    if (nav) {
      const onScroll = () => nav.classList.toggle("is-scrolled", window.scrollY > 12);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  </script>
</body>
</html>
